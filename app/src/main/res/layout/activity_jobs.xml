<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primaryDark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/primaryDarkLight">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/job_listings"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-bold" />

        <!-- Filter Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_all"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chipBackground"
                android:textColor="@color/chipText" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_fulltime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_fulltime"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chipBackground"
                android:textColor="@color/chipText" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_freelance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_freelance"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chipBackground"
                android:textColor="@color/chipText" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_gig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_gig"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chipBackground"
                android:textColor="@color/chipText" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <!-- Jobs List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_jobs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />
</LinearLayout>
